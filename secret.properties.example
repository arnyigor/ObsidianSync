# Copy this file to secret.properties and keep the real file outside Git.
# Relative keystore paths are resolved from the repository root.
ANDROID_KEYSTORE_PATH=C:/Users/your-name/.android-keys/obsidelta-release.p12
ANDROID_KEYSTORE_PASSWORD=replace-with-keystore-password
ANDROID_KEY_ALIAS=obsidelta
ANDROID_KEY_PASSWORD=replace-with-key-password
